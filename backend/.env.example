GOOGLE_API_KEY=
E2B_API_KEY=
MAX_DEV_RETRIES=3
MAX_SEC_ITERATIONS=3
PORT=8000
HOST=0.0.0.0

# Multi-Model Config (Optimised for Rate-Sharing and Task Complexity)
DEVELOPER_MODEL=gemini-2.5-flash-lite
TRIAGE_MODEL=gemini-2.5-flash
SYNTHESIZER_MODEL=gemini-2.5-flash

# Optional: OpenRouter / OpenAI Config
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
# Get your API key at: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=CodeSentinel
LANGCHAIN_API_KEY=
