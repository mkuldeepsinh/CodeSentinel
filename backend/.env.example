GOOGLE_API_KEY=
E2B_API_KEY=
MAX_DEV_RETRIES=3
MAX_SEC_ITERATIONS=3
PORT=8000
HOST=0.0.0.0

# Multi-Model Config — Best confirmed free-tier models (as of June 2026)
# Developer Agent → fastest codegen, lowest latency
DEVELOPER_MODEL=gemini-2.5-flash-lite
# Triage Agent    → strongest reasoning + guaranteed Pydantic structured output
TRIAGE_MODEL=gemini-2.5-flash
# Synthesizer     → strong code rewriter
SYNTHESIZER_MODEL=gemini-2.5-flash

# Optional: OpenRouter free alternatives (check openrouter.ai/models for current :free availability)
# TRIAGE_MODEL=qwen/qwen3-coder:free          # Best free coder (1M ctx)
# TRIAGE_MODEL=nvidia/nemotron-super-49b-v1:free  # Strong reasoning

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
# Get your API key at: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=CodeSentinel
LANGCHAIN_API_KEY=
