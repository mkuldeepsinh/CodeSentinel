# Google API Key for Gemini Models
GOOGLE_API_KEY=your_google_api_key_here

# E2B API Key & Sandbox template configuration for secure runtime execution
E2B_API_KEY=your_e2b_api_key_here
E2B_TEMPLATE_ID=codesentinel-js

# Agent Execution Limits
MAX_DEV_RETRIES=3
MAX_SEC_ITERATIONS=3

# Backend Server Configuration
PORT=8000
HOST=0.0.0.0

# Database URL Connection String (Supports PostgreSQL / Supabase, falls back to SQLite internally if not set)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Model Configuration
DEVELOPER_MODEL=gemini-2.5-flash-lite
TRIAGE_MODEL=gemini-2.5-flash
SYNTHESIZER_MODEL=gemini-2.5-flash

# OpenRouter API Key (Optional fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LangSmith Tracing & Observability (Optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=CodeSentinel
LANGCHAIN_API_KEY=your_langsmith_api_key_here
